@startuml
!include ../C4_Component.puml

title Component Diagram: Smart Device Lifecycle Management

Container(device_service, "Smart Device Lifecycle Management", "Go", "Device registration and state")

System_Boundary(device_service_boundary, "Device Service") {
    Component(api, "REST API", "Go HTTP", "API for device management")
    Component(manager, "Device Manager", "Go", "Management business logic")
    Component(repository, "Repository", "GORM", "Database access")
}

ContainerDb(device_db, "Smart Device Database", "PostgreSQL", "External Database")
ContainerQueue(message_broker, "Asynchronous Event Bus", "RabbitMQ", "External broker")

Rel(api, manager, "Calls", "")
Rel(manager, repository, "Uses", "")
Rel(repository, device_db, "Reads/Writes", "SQL")

Rel(manager, message_broker, "Publishes state events", "AMQP")
Rel(message_broker, manager, "Receives device commands", "AMQP")
@enduml